# ============================================================
# STREAMLINE BACKEND — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- DATABASE -------------------------------------------
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/streamline_db

# ---- SERVER ---------------------------------------------
PORT=3000
NODE_ENV=development

# ---- CORS -----------------------------------------------
# Frontend URL — must be exact (no trailing slash)
CORS_ORIGIN=http://localhost:5173

# ---- AUTH -----------------------------------------------
# JWT secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_in_production
