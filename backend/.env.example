# ============================================================
# STREAMLINE BACKEND — Environment Variables
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your values
# 3. NEVER commit .env to version control
#
# In production: use your platform's secret manager
# (Railway Variables, Render Environment, Doppler, etc.)
# ============================================================

# ---- DATABASE [REQUIRED] -----------------------------------
# PostgreSQL connection string
# Local:      postgresql://postgres:password@localhost:5432/streamline_db
# Railway:    provided automatically as $DATABASE_URL
# Supabase:   Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:password@localhost:5432/streamline_db

# ---- AUTH [REQUIRED] ---------------------------------------
# JWT signing secret — must be long and random
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Min recommended: 32 characters
# In production: inject from secret manager, never hardcode
JWT_SECRET=replace_with_output_of_generate_command_above

# ---- SERVER [OPTIONAL — has defaults] ----------------------
PORT=3000
NODE_ENV=development

# ---- CORS [OPTIONAL — has defaults] ------------------------
# Frontend URL — no trailing slash
# Production: set to your actual frontend domain
CORS_ORIGIN=http://localhost:5173
