# ============================================================
# STREAMLINE — Root Environment Variables
# This file documents all variables across the monorepo.
# Each package has its own .env — see backend/ and frontend/.
# ============================================================

# ---- BACKEND (backend/.env) -----------------------------
# DATABASE_URL=postgresql://postgres:password@localhost:5432/streamline_db
# PORT=3000
# NODE_ENV=development
# CORS_ORIGIN=http://localhost:5173
# JWT_SECRET=change_this_to_a_long_random_secret_in_production

# ---- FRONTEND (frontend/.env) ---------------------------
# VITE_API_URL=http://localhost:3000
